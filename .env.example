# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Postgres ----
POSTGRES_USER=social_feed
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=social_feed
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Prisma — read by prisma CLI and PrismaPg adapter at runtime
DATABASE_URL="postgresql://social_feed:change_me_in_local_env@localhost:5432/social_feed?schema=public"

# ---- pgAdmin (development only — remove for production delivery) ----
PGADMIN_DEFAULT_EMAIL=admin@social-feed.local
PGADMIN_DEFAULT_PASSWORD=change_me_in_local_env
PGADMIN_PORT=5050
